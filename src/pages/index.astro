---
import Base from '../layouts/Base.astro';

const title = 'Open_ | Learn to build real things with AI';
const description = 'A free 12-week cohort where you learn to build real products with AI. Not a coding bootcamp. Not prompt engineering. You build and ship something real.';

const SWORD_FORM_URL = '#';
const DISCORD_URL = '#';
const TWITTER_URL = 'https://x.com/joinopen';
const COHORT_CAP = 100;
---

<Base title={title} description={description}>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:bg-open-accent focus:text-open-black focus:px-4 focus:py-2 focus:rounded focus:z-[60]">
    Skip to content
  </a>

  <!-- Custom cursor (desktop) -->
  <div id="custom-cursor" class="custom-cursor" aria-hidden="true">
    <div class="cursor-dot"></div>
    <div class="cursor-ring"></div>
  </div>

  <!-- Cursor spotlight -->
  <div id="cursor-spotlight" class="cursor-spotlight" aria-hidden="true"></div>

  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 glass-nav">
    <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="#" class="text-xl font-bold tracking-tight">Open<span class="text-open-accent">_</span></a>
      <a
        href="#sword"
        class="magnetic glow-button text-sm font-medium bg-open-accent/10 text-open-accent px-4 py-2 rounded-lg relative z-10"
      >
        Submit Your Sword →
      </a>
    </div>
  </nav>

  <main id="main-content">

    <!-- Hero with WebGL shader background -->
    <section class="relative pt-36 pb-28 px-6 overflow-hidden min-h-[90vh] flex items-center" id="hero">
      <!-- WebGL Canvas -->
      <canvas id="hero-shader" class="absolute inset-0 w-full h-full" aria-hidden="true"></canvas>

      <!-- Particles -->
      <div class="particles" aria-hidden="true">
        <div class="particle"></div><div class="particle"></div><div class="particle"></div>
        <div class="particle"></div><div class="particle"></div><div class="particle"></div>
        <div class="particle"></div><div class="particle"></div>
      </div>

      <div class="max-w-4xl mx-auto text-center relative z-10 hero-parallax">
        <div class="reveal">
          <h1 class="text-5xl sm:text-6xl lg:text-8xl font-bold tracking-tight leading-[1.05] mb-8">
            <span class="scramble-text gradient-text" data-text="Learn to build">Learn to build</span><br />
            <span class="scramble-text gradient-text" data-text="real things" data-delay="400">real things</span><br />
            <span class="scramble-text accent-gradient-text" data-text="with AI." data-delay="800">with AI.</span>
          </h1>
        </div>

        <div class="reveal" style="transition-delay: 200ms;">
          <p class="text-lg sm:text-xl text-open-gray max-w-2xl mx-auto leading-relaxed mb-6">
            I went from a $120k software engineer to making over $200k, plus freelancing
            at $100 an hour. Before that I could only handle my full-time job. What changed?
            I learned how to build with AI. Open_ is a free, 12-week cohort that teaches
            you how to do what I did. Think
            <a href="https://leonnoel.com/100devs/" target="_blank" rel="noopener" class="underline decoration-open-accent/40 underline-offset-4 hover:text-open-white hover:decoration-open-accent transition-all">100Devs</a>,
            but for the AI era.
          </p>
        </div>

        <div class="reveal" style="transition-delay: 400ms;">
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10">
            <a
              href="#sword"
              class="magnetic glow-button inline-flex items-center gap-2 bg-open-accent text-open-black font-semibold px-8 py-3.5 rounded-xl text-base relative z-10"
            >
              Submit Your Sword →
            </a>
            <span class="text-sm text-open-gray">
              Cohort 1 · <strong class="text-open-white">Summer 2026</strong> · US only
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats bar with animated counters -->
    <section class="section-fade py-6 px-6 relative z-10">
      <div class="max-w-3xl mx-auto">
        <div class="glass rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-around gap-6 text-center">
          <div class="reveal">
            <div class="text-3xl font-bold text-open-accent stat-number" data-count="12">0</div>
            <div class="text-xs text-open-gray uppercase tracking-wider mt-1">Weeks</div>
          </div>
          <div class="hidden sm:block w-px h-8 bg-white/10"></div>
          <div class="reveal">
            <div class="text-3xl font-bold text-open-white" data-prefix="$" data-count="0">$0</div>
            <div class="text-xs text-open-gray uppercase tracking-wider mt-1">Cost</div>
          </div>
          <div class="hidden sm:block w-px h-8 bg-white/10"></div>
          <div class="reveal">
            <div class="text-3xl font-bold text-open-white stat-number" data-count="100">0</div>
            <div class="text-xs text-open-gray uppercase tracking-wider mt-1">Spots</div>
          </div>
          <div class="hidden sm:block w-px h-8 bg-white/10"></div>
          <div class="reveal">
            <div class="text-3xl font-bold text-open-white stat-number" data-count="1">0</div>
            <div class="text-xs text-open-gray uppercase tracking-wider mt-1">Shipped product</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="section-fade py-20 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="reveal">
          <h2 class="text-3xl sm:text-4xl font-bold mb-12 text-center">Who this is for</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 reveal-stagger reveal">
          <div class="glass glass-tilt rounded-xl p-6">
            <div class="text-2xl mb-3">⚡</div>
            <h3 class="font-semibold text-open-accent mb-3 text-lg">Employees</h3>
            <p class="text-sm text-open-gray leading-relaxed">You want to build AI tools for your job, automate the boring stuff, or build something on the side that could become your way out.</p>
          </div>
          <div class="glass glass-tilt rounded-xl p-6">
            <div class="text-2xl mb-3">🛠</div>
            <h3 class="font-semibold text-open-accent mb-3 text-lg">Freelancers</h3>
            <p class="text-sm text-open-gray leading-relaxed">You already do client work. You want to add AI-powered tools or services to what you offer. Things you couldn't build before.</p>
          </div>
          <div class="glass glass-tilt rounded-xl p-6">
            <div class="text-2xl mb-3">📈</div>
            <h3 class="font-semibold text-open-accent mb-3 text-lg">Business owners</h3>
            <p class="text-sm text-open-gray leading-relaxed">You've been paying other people to build tools you need. AI makes it possible to build them yourself. This teaches you how.</p>
          </div>
          <div class="glass glass-tilt rounded-xl p-6">
            <div class="text-2xl mb-3">🚀</div>
            <h3 class="font-semibold text-open-accent mb-3 text-lg">Aspiring founders</h3>
            <p class="text-sm text-open-gray leading-relaxed">You have an idea but haven't built it yet. By the end you'll have a shipped product with actual users. Not a pitch deck.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Schedule -->
    <section class="section-fade py-20 px-6 dot-grid">
      <div class="max-w-3xl mx-auto">
        <div class="reveal">
          <h2 class="text-3xl sm:text-4xl font-bold mb-12 text-center">The schedule</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-4 reveal-stagger reveal">
          <div class="glass glass-tilt rounded-xl p-5">
            <div class="flex items-center gap-3 mb-2">
              <span class="w-2 h-2 rounded-full bg-open-accent animate-pulse"></span>
              <span class="text-open-accent font-mono text-xs tracking-wider uppercase">Tuesday</span>
            </div>
            <p class="text-open-white font-medium">2-hour live session on Twitch</p>
            <p class="text-sm text-open-gray mt-1">New concepts, live building, questions welcome.</p>
          </div>
          <div class="glass glass-tilt rounded-xl p-5">
            <div class="flex items-center gap-3 mb-2">
              <span class="w-2 h-2 rounded-full bg-open-accent animate-pulse"></span>
              <span class="text-open-accent font-mono text-xs tracking-wider uppercase">Thursday</span>
            </div>
            <p class="text-open-white font-medium">2-hour live session on Twitch</p>
            <p class="text-sm text-open-gray mt-1">Deeper dives, working on projects together.</p>
          </div>
          <div class="glass glass-tilt rounded-xl p-5">
            <div class="flex items-center gap-3 mb-2">
              <span class="w-2 h-2 rounded-full bg-open-accent/60"></span>
              <span class="text-open-accent font-mono text-xs tracking-wider uppercase">Sunday</span>
            </div>
            <p class="text-open-white font-medium">Office hours</p>
            <p class="text-sm text-open-gray mt-1">Bring whatever you're stuck on. Get help from me and the cohort.</p>
          </div>
          <div class="glass glass-tilt rounded-xl p-5">
            <div class="flex items-center gap-3 mb-2">
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
              <span class="text-green-400 font-mono text-xs tracking-wider uppercase">24/7</span>
            </div>
            <p class="text-open-white font-medium">Discord</p>
            <p class="text-sm text-open-gray mt-1">Home base. You'll be in a Crew of 5–6 people. They're your accountability group.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 12-week structure -->
    <section class="section-fade py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="reveal text-center mb-14">
          <h2 class="text-3xl sm:text-4xl font-bold mb-3">12 weeks. 3 phases.</h2>
          <p class="text-open-gray text-lg">10 weeks of content + 2 break weeks built in for catching up and not burning out.</p>
        </div>
        <div class="relative space-y-0">
          <div class="hidden sm:block absolute left-[7.5rem] top-0 bottom-0 w-px bg-gradient-to-b from-open-accent/50 via-white/5 to-open-accent/50"></div>

          <!-- Phase 1 -->
          <div class="relative flex flex-col sm:flex-row gap-4 sm:gap-8 pb-10 reveal">
            <div class="sm:w-[7.5rem] shrink-0 text-right">
              <span class="text-open-accent font-mono text-sm font-medium">Weeks 1–3</span>
            </div>
            <div class="sm:pl-8 timeline-dot">
              <div class="gradient-border rounded-xl p-6">
                <h3 class="text-xl font-semibold mb-3">Foundations</h3>
                <p class="text-open-gray text-sm leading-relaxed mb-3">
                  Week 1 isn't code. It's how to think. Mental health, scheduling, problem
                  decomposition. You learn to break down what you want before you touch any AI tool.
                  Week 2 you learn the process: talk through the idea, write a spec, poke holes in it,
                  build one piece at a time.
                </p>
                <p class="text-open-gray text-sm leading-relaxed">
                  Week 3 is a hackathon. You and your Crew build something together.
                  Spec it, stress-test it, ship it. Every team presents what they built.
                </p>
              </div>
            </div>
          </div>

          <div class="relative flex flex-col sm:flex-row gap-4 sm:gap-8 pb-10 reveal">
            <div class="sm:w-[7.5rem] shrink-0 text-right">
              <span class="text-open-gray font-mono text-xs uppercase tracking-wider">Week 4</span>
            </div>
            <div class="sm:pl-8 timeline-dot timeline-dot-dim">
              <p class="text-open-gray text-sm italic py-3">Break. Catch up, breathe, reflect.</p>
            </div>
          </div>

          <!-- Phase 2 -->
          <div class="relative flex flex-col sm:flex-row gap-4 sm:gap-8 pb-10 reveal">
            <div class="sm:w-[7.5rem] shrink-0 text-right">
              <span class="text-open-accent font-mono text-sm font-medium">Weeks 5–8</span>
            </div>
            <div class="sm:pl-8 timeline-dot">
              <div class="gradient-border rounded-xl p-6">
                <h3 class="text-xl font-semibold mb-3">Build your own</h3>
                <p class="text-open-gray text-sm leading-relaxed mb-3">
                  Pick something you want to exist. Could be a tool for your job, a side project,
                  a business idea. Whatever. Spec it, get it reviewed by your Crew, and build.
                </p>
                <p class="text-open-gray text-sm leading-relaxed">
                  Week 8 I teach freelancing. Not theory, the actual mechanics. My proposal
                  template, how I find clients, how I charge $100/hr and why people pay it.
                  You can start freelancing before the cohort even ends.
                </p>
              </div>
            </div>
          </div>

          <div class="relative flex flex-col sm:flex-row gap-4 sm:gap-8 pb-10 reveal">
            <div class="sm:w-[7.5rem] shrink-0 text-right">
              <span class="text-open-gray font-mono text-xs uppercase tracking-wider">Week 9</span>
            </div>
            <div class="sm:pl-8 timeline-dot timeline-dot-dim">
              <p class="text-open-gray text-sm italic py-3">Break. Rest up before the final push.</p>
            </div>
          </div>

          <!-- Phase 3 -->
          <div class="relative flex flex-col sm:flex-row gap-4 sm:gap-8 reveal">
            <div class="sm:w-[7.5rem] shrink-0 text-right">
              <span class="text-open-accent font-mono text-sm font-medium">Weeks 10–12</span>
            </div>
            <div class="sm:pl-8 timeline-dot">
              <div class="gradient-border rounded-xl p-6">
                <h3 class="text-xl font-semibold mb-3">Ship it</h3>
                <p class="text-open-gray text-sm leading-relaxed mb-3">
                  Polish, deploy, launch. Week 10 I show you how I used these skills to go from
                  $120k to $200k+ at my day job. Week 11 is launch week. Everyone ships publicly.
                </p>
                <p class="text-open-gray text-sm leading-relaxed">
                  Not everyone will ship by Week 12. That's okay. The cohort ends, but the Discord
                  doesn't. The process is yours forever and the community keeps going. You either
                  ship during or you ship after. The only way to fail is to stop.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What this is NOT -->
    <section class="section-fade py-20 px-6 dot-grid">
      <div class="max-w-3xl mx-auto">
        <div class="reveal">
          <h2 class="text-3xl sm:text-4xl font-bold mb-12 text-center">What this is <span class="accent-gradient-text">not</span></h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-4 reveal-stagger reveal">
          <div class="glass rounded-xl p-5 flex items-start gap-3">
            <span class="text-open-accent text-lg mt-0.5 shrink-0">✕</span>
            <span class="text-open-gray text-sm leading-relaxed">Not a coding bootcamp. You don't need to learn programming languages. You need to know how to use an IDE as a text editor.</span>
          </div>
          <div class="glass rounded-xl p-5 flex items-start gap-3">
            <span class="text-open-accent text-lg mt-0.5 shrink-0">✕</span>
            <span class="text-open-gray text-sm leading-relaxed">Not a prompt engineering course. Learning to "talk to ChatGPT better" isn't what this is.</span>
          </div>
          <div class="glass rounded-xl p-5 flex items-start gap-3">
            <span class="text-open-accent text-lg mt-0.5 shrink-0">✕</span>
            <span class="text-open-gray text-sm leading-relaxed">Not a get-rich-quick thing. This is 12 weeks of actual work. If you want shortcuts, this isn't it.</span>
          </div>
          <div class="glass rounded-xl p-5 flex items-start gap-3">
            <span class="text-open-accent text-lg mt-0.5 shrink-0">✕</span>
            <span class="text-open-gray text-sm leading-relaxed">Not passive. You can't just watch the streams and get the value. You have to build.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-fade py-20 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="reveal">
          <h2 class="text-3xl sm:text-4xl font-bold mb-12 text-center">Questions you probably have</h2>
        </div>
        <div class="space-y-4 reveal">
          <details class="group glass rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5">
              <span class="font-semibold">Do I need to know how to code?</span>
              <span class="text-open-accent group-open:rotate-45 transition-transform duration-200 text-xl leading-none">+</span>
            </summary>
            <div class="px-5 pb-5 border-t border-white/5 pt-4">
              <p class="text-sm text-open-gray leading-relaxed">No. You need to be comfortable using a computer and willing to learn how a text editor works. The whole point of this cohort is that AI does the coding. You learn how to think clearly and direct it.</p>
            </div>
          </details>
          <details class="group glass rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5">
              <span class="font-semibold">How much time per week?</span>
              <span class="text-open-accent group-open:rotate-45 transition-transform duration-200 text-xl leading-none">+</span>
            </summary>
            <div class="px-5 pb-5 border-t border-white/5 pt-4">
              <p class="text-sm text-open-gray leading-relaxed">Plan for about 10 hours. That's 4 hours of live sessions (Tues + Thurs), office hours on Sunday, and daily homework. If you can't do 10, you can still get value, but the people who build the most are the ones who show up consistently.</p>
            </div>
          </details>
          <details class="group glass rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5">
              <span class="font-semibold">What if I can't finish in 12 weeks?</span>
              <span class="text-open-accent group-open:rotate-45 transition-transform duration-200 text-xl leading-none">+</span>
            </summary>
            <div class="px-5 pb-5 border-t border-white/5 pt-4">
              <p class="text-sm text-open-gray leading-relaxed">That's what the break weeks are for. And it's also why the Discord stays open after the cohort ends. You either ship during or you ship after. The process and the community are yours to keep.</p>
            </div>
          </details>
          <details class="group glass rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer p-5">
              <span class="font-semibold">Is this really free?</span>
              <span class="text-open-accent group-open:rotate-45 transition-transform duration-200 text-xl leading-none">+</span>
            </summary>
            <div class="px-5 pb-5 border-t border-white/5 pt-4">
              <p class="text-sm text-open-gray leading-relaxed">Yes. No hidden fees, no upsell, no premium tier. 100Devs was free and it changed my life. This is me paying that forward.</p>
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- The Sword -->
    <section id="sword" class="section-fade py-24 px-6 relative overflow-hidden">
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-[600px] h-[600px] bg-open-accent/5 rounded-full blur-[150px] animate-pulse-slow"></div>
      </div>

      <div class="max-w-3xl mx-auto relative z-10">
        <div class="reveal text-center mb-8">
          <h2 class="text-3xl sm:text-4xl font-bold mb-6">The Sword</h2>
        </div>
        <div class="reveal gradient-border rounded-2xl p-8 sm:p-10">
          <div class="text-left max-w-xl mx-auto">
            <p class="text-open-gray mb-4 leading-relaxed">
              To apply, you build something first. We call it the Sword.
            </p>
            <p class="text-open-gray mb-4 leading-relaxed">
              It doesn't need to be big or impressive. It needs to be yours. Use any AI tool you want.
              ChatGPT, Claude, Copilot, whatever. Build something: a landing page, a bot, a small tool
              that solves a problem you actually have.
            </p>
            <p class="text-open-gray mb-4 leading-relaxed">
              The point isn't the output. It's the process. We want to see that you tried,
              got stuck, figured things out, and can talk about what happened. Document your build:
              what you asked the AI, what worked, what didn't, what you learned.
            </p>
            <p class="text-open-gray mb-8 leading-relaxed text-sm opacity-70">
              There's no trick to it. If you put in real effort and can explain what you did,
              you're in. If you paste in a ChatGPT response and call it done, you're not.
            </p>
          </div>
          <div class="text-center">
            <a
              href={SWORD_FORM_URL}
              target="_blank"
              rel="noopener"
              class="magnetic glow-button inline-flex items-center gap-2 bg-open-accent text-open-black font-semibold px-10 py-4 rounded-xl text-lg relative z-10"
            >
              Submit Your Sword →
            </a>
            <p class="text-xs text-open-gray mt-5">
              Cohort 1 is capped at {COHORT_CAP} people. US only for now.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- About Cnid -->
    <section class="section-fade py-20 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="reveal">
          <h2 class="text-3xl sm:text-4xl font-bold mb-10 text-center">Who's running this</h2>
        </div>
        <div class="reveal gradient-border rounded-2xl p-8 sm:p-10">
          <div class="text-open-gray space-y-4 leading-relaxed relative">
            <p>
              I'm Cnid. Senior software engineer. I already knew how to code, but
              <a href="https://leonnoel.com/100devs/" target="_blank" rel="noopener" class="underline decoration-open-accent/40 underline-offset-4 hover:text-open-white hover:decoration-open-accent transition-all">100Devs</a>
              made me a better engineer. Leon, thank you for everything you've done
              for me and everyone else. Open_ is me trying to pay that forward for the AI era.
            </p>
            <p>
              I've been building with AI since ChatGPT 3.5 dropped. And like most people,
              I started by just throwing ideas at it and seeing what came back. That works for
              small stuff. The second you try to build something real, it falls apart.
            </p>
            <p>
              So I stopped doing that. Now I spend most of my time before I write any code.
              Just talking through the idea with AI, writing down what it should actually do,
              poking holes in the plan until it's solid. Then I build it one piece at a time.
              I've shipped a bunch of stuff this way. This site was built this way.
              It's not magic, it's a process. That's what I'm teaching.
            </p>
            <p>
              Why is this free? Because 100Devs was free and it changed everything for me.
              That's it. No upsell, no premium tier, no catch.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 px-6 section-fade">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row gap-6 items-start sm:items-center justify-between">
        <div>
          <p class="font-bold text-lg">Open<span class="text-open-accent">_</span></p>
          <p class="text-sm text-open-gray mt-1">Free. 12 weeks. Ship something real.</p>
        </div>
        <div class="flex gap-6 text-sm">
          <a href={DISCORD_URL} target="_blank" rel="noopener" class="text-open-gray hover:text-open-white transition-colors">Discord</a>
          <a href={TWITTER_URL} target="_blank" rel="noopener" class="text-open-gray hover:text-open-white transition-colors">@joinopen</a>
          <a href="#sword" class="text-open-accent hover:text-orange-400 transition-colors">Submit Your Sword</a>
        </div>
      </div>
    </footer>

  </main>

  <!-- ==========================================
       WEBGL METABALL SHADER + INTERACTION JS
       ========================================== -->
  <script>
    // ---- WebGL Metaball Shader ----
    const canvas = document.getElementById('hero-shader') as HTMLCanvasElement;
    if (canvas) {
      const gl = canvas.getContext('webgl', { alpha: true, antialias: false, premultipliedAlpha: false });
      if (gl) {
        // Vertex shader (fullscreen quad)
        const vs = `attribute vec2 a_pos;void main(){gl_Position=vec4(a_pos,0,1);}`;

        // Fragment shader: metaballs with smooth coloring
        const fs = `
precision mediump float;
uniform float u_time;
uniform vec2 u_resolution;
uniform vec2 u_mouse;

float metaball(vec2 p, vec2 c, float r) {
  float d = length(p - c);
  return r * r / (d * d + 0.001);
}

void main() {
  vec2 p = (gl_FragCoord.xy - u_resolution * 0.5) / min(u_resolution.x, u_resolution.y);
  float t = u_time * 0.25;

  // 6 autonomous metaballs (bigger radii)
  float v = 0.0;
  v += metaball(p, vec2(sin(t*0.7)*0.5, cos(t*0.6)*0.4), 0.30);
  v += metaball(p, vec2(cos(t*0.5)*0.6, sin(t*0.8)*0.5), 0.25);
  v += metaball(p, vec2(sin(t*0.9+2.0)*0.4, cos(t*0.4+1.0)*0.6), 0.32);
  v += metaball(p, vec2(cos(t*0.6+4.0)*0.7, sin(t*0.7+3.0)*0.3), 0.22);
  v += metaball(p, vec2(sin(t*0.4+5.0)*0.3, cos(t*0.9+2.0)*0.5), 0.28);
  v += metaball(p, vec2(cos(t*0.8+1.0)*0.5, sin(t*0.5+4.0)*0.4), 0.24);

  // Mouse-following metaball (large)
  vec2 mp = (u_mouse - u_resolution * 0.5) / min(u_resolution.x, u_resolution.y);
  v += metaball(p, mp, 0.35);

  // Color: orange-amber gradient
  float edge = smoothstep(0.4, 1.0, v);
  float core = smoothstep(1.0, 2.0, v);
  float bright = smoothstep(2.0, 3.5, v);

  vec3 orange = vec3(0.976, 0.451, 0.086);  // #f97316
  vec3 amber  = vec3(0.984, 0.573, 0.235);  // #fb923c
  vec3 hot    = vec3(1.0, 0.75, 0.4);

  vec3 col = mix(orange * 0.6, orange, edge);
  col = mix(col, amber, core);
  col = mix(col, hot, bright * 0.5);

  // Outer glow: visible even at low field values
  float outerGlow = smoothstep(0.15, 0.5, v);

  // Alpha: much more visible
  float alpha = outerGlow * 0.25 + edge * 0.35 + core * 0.15;

  gl_FragColor = vec4(col, alpha);
}`;

        function createShader(type: number, source: string) {
          const s = gl!.createShader(type)!;
          gl!.shaderSource(s, source);
          gl!.compileShader(s);
          return s;
        }

        const prog = gl.createProgram()!;
        gl.attachShader(prog, createShader(gl.VERTEX_SHADER, vs));
        gl.attachShader(prog, createShader(gl.FRAGMENT_SHADER, fs));
        gl.linkProgram(prog);
        gl.useProgram(prog);

        // Fullscreen quad
        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1,1,-1,-1,1,1,1]), gl.STATIC_DRAW);
        const aPos = gl.getAttribLocation(prog, 'a_pos');
        gl.enableVertexAttribArray(aPos);
        gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

        const uTime = gl.getUniformLocation(prog, 'u_time');
        const uRes = gl.getUniformLocation(prog, 'u_resolution');
        const uMouse = gl.getUniformLocation(prog, 'u_mouse');

        let mouseX = 0, mouseY = 0;
        let targetMouseX = 0, targetMouseY = 0;

        document.addEventListener('mousemove', (e) => {
          targetMouseX = e.clientX * devicePixelRatio;
          targetMouseY = (canvas.clientHeight - e.clientY) * devicePixelRatio;
        });

        function resize() {
          const dpr = Math.min(devicePixelRatio, 2);
          canvas.width = canvas.clientWidth * dpr;
          canvas.height = canvas.clientHeight * dpr;
          gl!.viewport(0, 0, canvas.width, canvas.height);
        }

        window.addEventListener('resize', resize);
        resize();

        gl.enable(gl.BLEND);
        gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);

        let startTime = performance.now();
        let rafId: number;

        function render() {
          // Smooth mouse following
          mouseX += (targetMouseX - mouseX) * 0.05;
          mouseY += (targetMouseY - mouseY) * 0.05;

          const t = (performance.now() - startTime) / 1000;
          gl!.uniform1f(uTime, t);
          gl!.uniform2f(uRes, canvas.width, canvas.height);
          gl!.uniform2f(uMouse, mouseX, mouseY);
          gl!.clearColor(0, 0, 0, 0);
          gl!.clear(gl!.COLOR_BUFFER_BIT);
          gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
          rafId = requestAnimationFrame(render);
        }

        // Only run when hero is visible
        const heroObserver = new IntersectionObserver(([entry]) => {
          if (entry.isIntersecting) {
            startTime = performance.now();
            render();
          } else {
            cancelAnimationFrame(rafId);
          }
        }, { threshold: 0 });
        heroObserver.observe(canvas);
      }
    }

    // ---- Custom Cursor ----
    const cursor = document.getElementById('custom-cursor');
    const cursorDot = cursor?.querySelector('.cursor-dot') as HTMLElement;
    const cursorRing = cursor?.querySelector('.cursor-ring') as HTMLElement;
    const spotlight = document.getElementById('cursor-spotlight');

    if (cursor && window.matchMedia('(pointer: fine)').matches) {
      let cx = 0, cy = 0, rx = 0, ry = 0;

      document.addEventListener('mousemove', (e) => {
        cx = e.clientX;
        cy = e.clientY;
        if (spotlight) {
          spotlight.style.left = cx + 'px';
          spotlight.style.top = cy + 'px';
        }
      });

      // Ring follows with lag
      function updateCursor() {
        rx += (cx - rx) * 0.15;
        ry += (cy - ry) * 0.15;
        if (cursorDot) {
          cursorDot.style.left = cx + 'px';
          cursorDot.style.top = cy + 'px';
        }
        if (cursorRing) {
          cursorRing.style.left = rx + 'px';
          cursorRing.style.top = ry + 'px';
        }
        requestAnimationFrame(updateCursor);
      }
      updateCursor();

      // Grow on interactive elements
      document.querySelectorAll('a, button, summary, .glass').forEach(el => {
        el.addEventListener('mouseenter', () => cursor.classList.add('cursor-hover'));
        el.addEventListener('mouseleave', () => cursor.classList.remove('cursor-hover'));
      });
    } else if (cursor) {
      cursor.style.display = 'none';
      if (spotlight) spotlight.style.display = 'none';
    }

    // ---- Scroll Reveal ----
    const revealObserver = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          revealObserver.unobserve(e.target);
        }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => revealObserver.observe(el));

    // ---- Glass Tilt (mouse-tracking light) ----
    document.querySelectorAll('.glass-tilt').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const evt = e as MouseEvent;
        const rect = (evt.currentTarget as HTMLElement).getBoundingClientRect();
        const x = ((evt.clientX - rect.left) / rect.width) * 100;
        const y = ((evt.clientY - rect.top) / rect.height) * 100;
        (evt.currentTarget as HTMLElement).style.setProperty('--mouse-x', x + '%');
        (evt.currentTarget as HTMLElement).style.setProperty('--mouse-y', y + '%');
      });
    });

    // ---- Magnetic Buttons ----
    document.querySelectorAll('.magnetic').forEach(btn => {
      btn.addEventListener('mousemove', (e) => {
        const evt = e as MouseEvent;
        const rect = (evt.currentTarget as HTMLElement).getBoundingClientRect();
        const x = evt.clientX - rect.left - rect.width / 2;
        const y = evt.clientY - rect.top - rect.height / 2;
        (evt.currentTarget as HTMLElement).style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
      });
      btn.addEventListener('mouseleave', (e) => {
        (e.currentTarget as HTMLElement).style.transform = '';
      });
    });

    // ---- Text Scramble ----
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%&*';
    document.querySelectorAll('.scramble-text').forEach(el => {
      const target = (el as HTMLElement).dataset.text || el.textContent || '';
      const delay = parseInt((el as HTMLElement).dataset.delay || '0');
      let frame = 0;
      const totalFrames = 30;

      // Start invisible
      el.textContent = target.replace(/[^\s]/g, ' ');

      setTimeout(() => {
        const interval = setInterval(() => {
          let result = '';
          for (let i = 0; i < target.length; i++) {
            if (target[i] === ' ') {
              result += ' ';
            } else if (frame / totalFrames > i / target.length) {
              result += target[i];
            } else {
              result += chars[Math.floor(Math.random() * chars.length)];
            }
          }
          el.textContent = result;
          frame++;
          if (frame > totalFrames) clearInterval(interval);
        }, 30);
      }, 300 + delay);
    });

    // ---- Animated Counters ----
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.count || '0');
        const prefix = el.dataset.prefix || '';
        if (target === 0) { el.textContent = prefix + '0'; counterObserver.unobserve(el); return; }

        const duration = 1500;
        const start = performance.now();

        function tick(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
          const current = Math.round(eased * target);
          el.textContent = prefix + current.toString();
          if (progress < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
        counterObserver.unobserve(el);
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('[data-count]').forEach(el => counterObserver.observe(el));

    // ---- Hero Parallax on scroll ----
    const heroContent = document.querySelector('.hero-parallax') as HTMLElement;
    if (heroContent && window.matchMedia('(pointer: fine)').matches) {
      window.addEventListener('scroll', () => {
        const y = window.scrollY;
        heroContent.style.transform = `translateY(${y * 0.15}px)`;
        heroContent.style.opacity = Math.max(1 - y / 600, 0).toString();
      }, { passive: true });
    }
  </script>
